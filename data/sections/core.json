{
  "name": "core",
  "description": "核心属性",
  "data": [
    { "name": "name", "type": "string", "description": "单位标识名（唯一）", "example": "name: myTank" },
    { "name": "displayText", "type": "string", "description": "玩家可见的名称", "example": "displayText: 重型坦克" },
    { "name": "displayDescription", "type": "string", "description": "单位描述", "example": "displayDescription: 一辆重型坦克" },
    { "name": "displayLocaleKey", "type": "string", "description": "翻译文件键名(1.15)", "example": "displayLocaleKey: units.mechArtillery" },
    { "name": "price", "type": "int", "description": "造价（支持多资源）", "example": "price: 500" },
    { "name": "maxHp", "type": "int", "description": "生命值", "example": "maxHp: 200" },
    { "name": "mass", "type": "int", "description": "质量/重量", "example": "mass: 3000" },
    { "name": "radius", "type": "int", "description": "碰撞半径", "example": "radius: 20" },
    { "name": "buildSpeed", "type": "float / s", "description": "建造时间/速度，支持小数速度值或秒单位时间值", "example": "buildSpeed: 3s" },
    { "name": "techLevel", "type": "int", "description": "科技等级 1/2/3", "example": "techLevel: 1" },
    { "name": "isBio", "type": "bool", "description": "是否为生物单位", "example": "isBio: false" },
    { "name": "isBuilder", "type": "bool", "description": "是否为建造者", "example": "isBuilder: true" },
    { "name": "nanoFactorySpeed", "type": "float", "description": "工厂建造速度倍率(1.13)", "example": "nanoFactorySpeed: 1.2" },
    { "name": "isBuilding", "type": "bool", "description": "是否为建筑", "example": "isBuilding: true" },
    { "name": "isLocked", "type": "bool", "description": "禁止建造", "example": "isLocked: false" },
    { "name": "isUnselectable", "type": "bool", "description": "不可选中", "example": "isUnselectable: false" },
    { "name": "experimental", "type": "bool", "description": "标记为实验单位", "example": "experimental: false" },
    { "name": "fogOfWarSightRange", "type": "int", "description": "视野范围（格数）", "example": "fogOfWarSightRange: 10" },
    { "name": "energyMax", "type": "float", "description": "能量上限，用作炮塔弹药(1.15)", "example": "energyMax: 1" },
    { "name": "energyRegen", "type": "float", "description": "能量恢复速度(1.15)", "example": "energyRegen: 0.001" },
    { "name": "energyNeedsToRechargeToFull", "type": "bool", "description": "能量耗尽后需回满才能再开火(1.15)", "example": "energyNeedsToRechargeToFull: true" },
    { "name": "maxShield", "type": "int", "description": "最大护盾值", "example": "maxShield: 500" },
    { "name": "shieldRegen", "type": "float", "description": "护盾恢复速度(1.15)", "example": "shieldRegen: 0.15" },
    { "name": "shieldRenderRadius", "type": "int", "description": "护盾圈显示半径(1.15)", "example": "shieldRenderRadius: 12" },
    { "name": "armour", "type": "int", "description": "伤害减免值(1.13)", "example": "armour: 5" },
    { "name": "transportSlotsNeeded", "type": "int", "description": "运输占用格数", "example": "transportSlotsNeeded: 0" },
    { "name": "maxTransportingUnits", "type": "int", "description": "最大运输数", "example": "maxTransportingUnits: 4" },
    { "name": "transportUnitsRequireTag", "type": "string", "description": "仅运输指定标签(1.13)", "example": "transportUnitsRequireTag: smallTank, soldier" },
    { "name": "transportUnitsRequireMovementType", "type": "string", "description": "仅运输指定移动类型(1.13)", "example": "transportUnitsRequireMovementType: AIR, WATER" },
    { "name": "transportUnitsKeepBuiltUnits", "type": "bool", "description": "保留已造单位在运输器内(1.13)", "example": "transportUnitsKeepBuiltUnits: true" },
    { "name": "transportUnitsCanUnloadUnits", "type": "string", "description": "能否卸载单位（LogicBoolean）(1.13)", "example": "transportUnitsCanUnloadUnits: false" },
    { "name": "showOnMinimap", "type": "bool", "description": "在小地图显示", "example": "showOnMinimap: true" },
    { "name": "tags", "type": "string", "description": "标签（逗号分隔）", "example": "tags: tank, heavy" },
    { "name": "copyFrom", "type": "string", "description": "从其他 ini/template 文件继承单位数据，支持多文件逗号分隔", "example": "copyFrom: base.template" },
    { "name": "overrideAndReplace", "type": "string", "description": "覆盖替换指定单位，逗号分隔多单位", "example": "overrideAndReplace: builder, combatEngineer" },
    { "name": "dont_load", "type": "bool", "description": "不加载该单位，可用于被 copyFrom 引用的基类文件", "example": "dont_load: true" }
  ]
}
