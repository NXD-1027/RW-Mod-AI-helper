{
  "name": "effect",
  "description": "视觉特效",
  "data": [
    { "name": "drawType", "type": "drawType", "description": "渲染方式(1.15p9)", "example": "drawType: normal" },
    { "name": "image", "type": "string", "description": "特效贴图", "example": "image: explosion.png" },
    { "name": "imageShadow", "type": "imageShadow", "description": "阴影贴图", "example": "imageShadow: AUTO" },
    { "name": "stripIndex", "type": "int", "description": "内置贴图序号", "example": "stripIndex: 0" },
    { "name": "life", "type": "float", "description": "存活时间（默认200）", "example": "life: 200" },
    { "name": "lifeRandom", "type": "float", "description": "随机生命偏移(1.14)", "example": "lifeRandom: 50" },
    { "name": "scaleTo", "type": "float", "description": "缩放至", "example": "scaleTo: 1" },
    { "name": "scaleFrom", "type": "float", "description": "从缩放", "example": "scaleFrom: 0.5" },
    { "name": "color", "type": "string", "description": "颜色", "example": "color: #ff0000" },
    { "name": "alpha", "type": "float", "description": "透明度(0-1)", "example": "alpha: 1" },
    { "name": "teamColorRatio", "type": "float", "description": "队伍着色比例", "example": "teamColorRatio: 0.5" },
    { "name": "fadeInTime", "type": "float / s", "description": "淡入时间，支持小数或秒单位", "example": "fadeInTime: 0.5s" },
    { "name": "fadeOut", "type": "bool", "description": "淡出", "example": "fadeOut: true" },
    { "name": "attachedToUnit", "type": "bool", "description": "附着到单位", "example": "attachedToUnit: true" },
    { "name": "physics", "type": "bool", "description": "物理效果", "example": "physics: true" },
    { "name": "physicsGravity", "type": "float", "description": "物理重力", "example": "physicsGravity: 0.1" },
    { "name": "atmospheric", "type": "bool", "description": "空气阻力/风", "example": "atmospheric: true" },
    { "name": "alsoEmitEffects", "type": "string", "description": "额外发射特效(1.13)", "example": "alsoEmitEffects: CUSTOM:spark*3" },
    { "name": "alsoEmitEffectsOnDeath", "type": "string", "description": "死亡时发射特效(1.14)", "example": "alsoEmitEffectsOnDeath: CUSTOM:spark*3" },
    { "name": "ifSpawnFailsEmitEffects", "type": "string", "description": "生成失败则替换特效", "example": "ifSpawnFailsEmitEffects: CUSTOM:smoke" },
    { "name": "alsoPlaySound", "type": "string", "description": "播放音效(1.13)", "example": "alsoPlaySound: explosion" },
    { "name": "spawnChance", "type": "float", "description": "生成概率(0-1)", "example": "spawnChance: 0.5" },
    { "name": "createWhenOffscreen", "type": "bool", "description": "屏幕外创建(1.13)", "example": "createWhenOffscreen: true" },
    { "name": "createWhenZoomedOut", "type": "bool", "description": "缩放时创建(1.13)", "example": "createWhenZoomedOut: true" },
    { "name": "createWhenOverLiquid", "type": "bool", "description": "液体上创建(1.13)", "example": "createWhenOverLiquid: false" },
    { "name": "createWhenOverLand", "type": "bool", "description": "陆地上创建(1.13)", "example": "createWhenOverLand: true" },
    { "name": "showInFog", "type": "bool", "description": "迷雾中可见(1.13)", "example": "showInFog: false" },
    { "name": "priority", "type": "priority", "description": "渲染优先级(1.13)", "example": "priority: low" },
    { "name": "drawUnderUnits", "type": "bool", "description": "在单位下方渲染(1.13)", "example": "drawUnderUnits: false" },
    { "name": "shadow", "type": "bool", "description": "投射阴影", "example": "shadow: true" },
    { "name": "delayedStartTimer", "type": "float / s", "description": "延迟开始(1.13)，支持小数或秒单位", "example": "delayedStartTimer: 1s" },
    { "name": "liveAfterAttachedDies", "type": "bool", "description": "附着者死后继续存在(1.13)", "example": "liveAfterAttachedDies: true" },
    { "name": "xOffsetRelative", "type": "float", "description": "相对水平偏移", "example": "xOffsetRelative: 0" },
    { "name": "yOffsetRelative", "type": "float", "description": "相对垂直偏移", "example": "yOffsetRelative: 0" },
    { "name": "xOffsetAbsolute", "type": "float", "description": "绝对水平偏移", "example": "xOffsetAbsolute: 0" },
    { "name": "yOffsetAbsolute", "type": "float", "description": "绝对垂直偏移", "example": "yOffsetAbsolute: 0" },
    { "name": "hOffset", "type": "float", "description": "高度偏移", "example": "hOffset: 0" },
    { "name": "hSpeed", "type": "float", "description": "高度变化速度", "example": "hSpeed: 1" },
    { "name": "dirOffset", "type": "float", "description": "方向偏移", "example": "dirOffset: 0" },
    { "name": "dirSpeed", "type": "float", "description": "旋转速度", "example": "dirSpeed: 1" },
    { "name": "alwayStartDirAtZero", "type": "bool", "description": "始终从0方向开始", "example": "alwayStartDirAtZero: false" },
    { "name": "frameIndex", "type": "int", "description": "帧序号", "example": "frameIndex: 0" },
    { "name": "frameIndexRandom", "type": "bool", "description": "随机帧", "example": "frameIndexRandom: true" },
    { "name": "total_frames", "type": "int", "description": "总帧数", "example": "total_frames: 3" },
    { "name": "animateFrameStart", "type": "int", "description": "动画起始帧", "example": "animateFrameStart: 0" },
    { "name": "animateFrameEnd", "type": "int", "description": "动画结束帧", "example": "animateFrameEnd: 2" },
    { "name": "animateFramePingPong", "type": "bool", "description": "动画往返", "example": "animateFramePingPong: true" },
    { "name": "animateFrameSpeed", "type": "float / s", "description": "动画速度，支持小数或秒单位", "example": "animateFrameSpeed: 2s" },
    { "name": "animateFrameLooping", "type": "bool", "description": "循环动画(1.14)", "example": "animateFrameLooping: true" },
    { "name": "pivotOffset", "type": "float", "description": "枢轴偏移(1.15)", "example": "pivotOffset: 0" },
    { "name": "pivotOffsetRandom", "type": "float", "description": "随机枢轴偏移(1.15)", "example": "pivotOffsetRandom: 5" }
  ]
}
