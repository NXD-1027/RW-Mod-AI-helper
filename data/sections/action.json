{
  "name": "action",
  "description": "动作（UI可见）",
  "data": [
    { "name": "text", "type": "string", "description": "按钮文字（支持动态文本）", "example": "text: 开火" },
    { "name": "textPostFix", "type": "string", "description": "后缀文字(1.15)", "example": "textPostFix: ]" },
    { "name": "description", "type": "string", "description": "动作描述", "example": "description: 对目标区域开火" },
    { "name": "displayType", "type": "displayType", "description": "显示类型", "example": "displayType: upgrade" },
    { "name": "displayRemainingStockpile", "type": "bool", "description": "显示剩余库存", "example": "displayRemainingStockpile: true" },
    { "name": "pos", "type": "float", "description": "按钮位置", "example": "pos: 1" },
    { "name": "iconImage", "type": "string", "description": "按钮图标", "example": "iconImage: fireShot.png" },
    { "name": "iconExtraImage", "type": "string", "description": "额外图标(1.14)", "example": "iconExtraImage: fireShotNo.png" },
    { "name": "iconExtraColor", "type": "string", "description": "额外图标颜色(1.14)", "example": "iconExtraColor: #ff0000" },
    { "name": "price", "type": "string", "description": "动作价格", "example": "price: credits=5" },
    { "name": "isActive", "type": "bool", "description": "是否激活（默认true）", "example": "isActive: true" },
    { "name": "isVisible", "type": "bool", "description": "是否可见（默认true）", "example": "isVisible: true" },
    { "name": "isLocked", "type": "bool", "description": "是否锁定", "example": "isLocked: false" },
    { "name": "isLockedMessage", "type": "string", "description": "锁定提示", "example": "isLockedMessage: 弹药不足" },
    { "name": "allowMultipleInQueue", "type": "bool", "description": "允许队列多个", "example": "allowMultipleInQueue: true" },
    { "name": "onlyOneUnitAtATime", "type": "bool", "description": "每次只有一个单位使用", "example": "onlyOneUnitAtATime: true" },
    { "name": "isGuiBlinking", "type": "bool", "description": "UI闪烁(1.13.3)", "example": "isGuiBlinking: true" },
    { "name": "autoTrigger", "type": "string", "description": "自动触发条件", "example": "autoTrigger: if self.overWater()" },
    { "name": "autoTriggerOnEvent", "type": "string", "description": "事件触发(1.13.3)", "example": "autoTriggerOnEvent: queueItemCancelled" },
    { "name": "autoTriggerOnEventRecursionLimit", "type": "int", "description": "触发递归限制(1.15)", "example": "autoTriggerOnEventRecursionLimit: 4" },
    { "name": "buildSpeed", "type": "float / s", "description": "动作队列时间，支持小数或秒单位", "example": "buildSpeed: 5s" },
    { "name": "highPriorityQueue", "type": "bool", "description": "高优先级", "example": "highPriorityQueue: true" },
    { "name": "canPlayerCancel", "type": "bool", "description": "玩家可取消", "example": "canPlayerCancel: true" },
    { "name": "whenBuilding_cannotMove", "type": "bool", "description": "动作执行时无法移动", "example": "whenBuilding_cannotMove: true" },
    { "name": "whenBuilding_playAnimation", "type": "string", "description": "执行时播放动画", "example": "whenBuilding_playAnimation: firePrepare" },
    { "name": "whenBuilding_rotateTo", "type": "float", "description": "执行时旋转到角度", "example": "whenBuilding_rotateTo: 45" },
    { "name": "whenBuilding_temporarilyConvertTo", "type": "string", "description": "执行时临时变形(1.15)", "example": "whenBuilding_temporarilyConvertTo: cannon_uberState" },
    { "name": "whenBuilding_triggerAction", "type": "string", "description": "执行时触发动作(1.15)", "example": "whenBuilding_triggerAction: spawnMinions" },
    { "name": "requireConditional", "type": "string", "description": "条件要求", "example": "requireConditional: if self.resource.mass < 300" },
    { "name": "convertTo", "type": "string", "description": "变形为目标单位(1.13.3)", "example": "convertTo: fishLevel2" },
    { "name": "addEnergy", "type": "float", "description": "添加能量", "example": "addEnergy: 10" },
    { "name": "addResources", "type": "string", "description": "添加资源", "example": "addResources: credits=5" },
    { "name": "addResourcesWithLogic", "type": "string", "description": "逻辑添加资源(1.15)", "example": "addResourcesWithLogic: hp = self.parent.hp" },
    { "name": "setResourcesWithLogic", "type": "string", "description": "逻辑设置资源(1.15)", "example": "setResourcesWithLogic: energy = self.energy / 2" },
    { "name": "deleteSelf", "type": "bool", "description": "删除自身", "example": "deleteSelf: true" },
    { "name": "resetCustomTimer", "type": "string", "description": "重置自定义计时器", "example": "resetCustomTimer: true" },
    { "name": "setBodyRotation", "type": "float", "description": "设置身体旋转(1.13.3)", "example": "setBodyRotation: 270" },
    { "name": "setUnitStats", "type": "string", "description": "动态修改属性(1.15)", "example": "setUnitStats: maxShield += 20" },
    { "name": "resetUnitStats", "type": "bool", "description": "重置属性修改(1.15)", "example": "resetUnitStats: true" },
    { "name": "setUnitMemory", "type": "string", "description": "设置内存变量(1.15)", "example": "setUnitMemory: customText=hello" },
    { "name": "setHeight", "type": "float", "description": "设置高度(1.15)", "example": "setHeight: parent.height+5" },
    { "name": "setCustomTarget1", "type": "string", "description": "自定义目标1(1.15)", "example": "setCustomTarget1: self.parent" },
    { "name": "setCustomTarget2", "type": "string", "description": "自定义目标2(1.15)", "example": "setCustomTarget2: lastDamagedBy" },
    { "name": "sendMessageTo", "type": "string", "description": "发送消息给目标(1.15)", "example": "sendMessageTo: nearestUnit(withinRange=100, withTag=\"fish\")" },
    { "name": "alsoTriggerAction", "type": "string", "description": "同时触发动作", "example": "alsoTriggerAction: addCredits" },
    { "name": "alsoQueueAction", "type": "string", "description": "同时加入队列", "example": "alsoQueueAction: spawnMinions" },
    { "name": "fireTurretXAtGround", "type": "string", "description": "炮塔射击地面(1.13.3)", "example": "fireTurretXAtGround: nukeSilo" },
    { "name": "fireTurretXAtGround_count", "type": "int", "description": "发射数量(1.13.3)", "example": "fireTurretXAtGround_count: 3" },
    { "name": "spawnUnits", "type": "string", "description": "生成单位(1.13.3)", "example": "spawnUnits: heavyTank*5" },
    { "name": "produceUnits", "type": "string", "description": "生产单位(1.13.3)", "example": "produceUnits: builder*4" },
    { "name": "spawnEffects", "type": "string", "description": "生成特效(1.13.3)", "example": "spawnEffects: CUSTOM:puff" },
    { "name": "playSoundAtUnit", "type": "string", "description": "本地音效", "example": "playSoundAtUnit: engineStart.ogg" },
    { "name": "playSoundGlobally", "type": "string", "description": "全局音效", "example": "playSoundGlobally: hornWarn.ogg" },
    { "name": "playSoundToPlayer", "type": "string", "description": "玩家音效", "example": "playSoundToPlayer: confirm.wav" },
    { "name": "playAnimation", "type": "string", "description": "播放动画(1.13.3)", "example": "playAnimation: engageThrusters" },
    { "name": "addWaypoint_type", "type": "string", "description": "添加路径点类型(1.13.3)", "example": "addWaypoint_type: move" },
    { "name": "addWaypoint_prepend", "type": "bool", "description": "路径点插入到队首(1.13.3)", "example": "addWaypoint_prepend: false" },
    { "name": "clearAllWaypoints", "type": "bool", "description": "清除所有路径点(1.13.3)", "example": "clearAllWaypoints: true" },
    { "name": "clearActiveWaypoint", "type": "bool", "description": "清除当前路径点(1.13.3)", "example": "clearActiveWaypoint: true" },
    { "name": "teleportTo", "type": "string", "description": "传送(1.15p11)", "example": "teleportTo: memory.lastLocation" },
    { "name": "showMessageToPlayer", "type": "string", "description": "显示消息给玩家(1.13.3)", "example": "showMessageToPlayer: 发现隐藏敌人" },
    { "name": "showMessageToAllPlayers", "type": "string", "description": "显示消息给所有玩家(1.13.3)", "example": "showMessageToAllPlayers: %{self.playerName} 占领了一个点" },
    { "name": "takeResources", "type": "string", "description": "夺取资源(1.13.3)", "example": "takeResources: hp=5, gold=10" },
    { "name": "convertResource_from", "type": "string", "description": "资源转换-来源(1.13.3)", "example": "convertResource_from: juice" },
    { "name": "convertResource_to", "type": "string", "description": "资源转换-目标(1.13.3)", "example": "convertResource_to: sauce" },
    { "name": "temporarilyAddTags", "type": "string", "description": "临时添加标签(1.13.3)", "example": "temporarilyAddTags: emptyJuice" },
    { "name": "temporarilyRemoveTags", "type": "string", "description": "临时移除标签(1.13.3)", "example": "temporarilyRemoveTags: fullJuice" },
    { "name": "resetToDefaultTags", "type": "bool", "description": "重置标签(1.13.3)", "example": "resetToDefaultTags: true" },
    { "name": "addGlobalTeamTags", "type": "string", "description": "添加队伍全局标签(1.13.3)", "example": "addGlobalTeamTags: upgrade_energized" },
    { "name": "removeGlobalTeamTags", "type": "string", "description": "移除队伍全局标签(1.13.3)", "example": "removeGlobalTeamTags: buff_immune" },
    { "name": "disconnectFromParent", "type": "bool", "description": "断连父级(1.13.3)", "example": "disconnectFromParent: true" },
    { "name": "attachments_addNewUnits", "type": "string", "description": "添加附着单位(1.13.3)", "example": "attachments_addNewUnits: coreDefense*3" },
    { "name": "attachments_deleteNumUnits", "type": "int", "description": "移除附着单位(1.13.3)", "example": "attachments_deleteNumUnits: 3" },
    { "name": "addAllActionCooldownsTime", "type": "float / s", "description": "全局动作冷却(1.14)，支持小数或秒单位", "example": "addAllActionCooldownsTime: 4s" },
    { "name": "addActionCooldownTime", "type": "float / s", "description": "指定动作冷却(1.14)，支持小数或秒单位", "example": "addActionCooldownTime: 20s" },
    { "name": "clearAllActionCooldowns", "type": "bool", "description": "清除冷却(1.14)", "example": "clearAllActionCooldowns: true" },
    { "name": "switchToNeutralTeam", "type": "bool", "description": "切换为中立(1.13.3)", "example": "switchToNeutralTeam: false" },
    { "name": "switchToAggressiveTeam", "type": "bool", "description": "切换为敌对(1.13.3)", "example": "switchToAggressiveTeam: true" },
    { "name": "switchToTeam", "type": "string", "description": "切换到指定队伍(1.15)", "example": "switchToTeam: 2" },
    { "name": "alwaysSinglePress", "type": "bool", "description": "单击执行(1.14)", "example": "alwaysSinglePress: true" }
  ]
}
