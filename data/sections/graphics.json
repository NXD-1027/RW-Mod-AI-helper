{
  "name": "graphics",
  "description": "外观属性",
  "data": [
    { "name": "image", "type": "string", "description": "单位贴图路径", "example": "image: body.png" },
    { "name": "image_back", "type": "string", "description": "背景贴图（工厂用）", "example": "image_back: floor.png" },
    { "name": "image_shield", "type": "string", "description": "自定义护盾贴图(1.14)", "example": "image_shield: forcefield.png" },
    { "name": "image_wreak", "type": "string", "description": "残骸贴图", "example": "image_wreak: ded.png" },
    { "name": "image_turret", "type": "string", "description": "默认炮塔贴图", "example": "image_turret: gun.png" },
    { "name": "image_offsetX", "type": "int", "description": "贴图水平偏移", "example": "image_offsetX: 0" },
    { "name": "image_offsetY", "type": "int", "description": "贴图垂直偏移", "example": "image_offsetY: 0" },
    { "name": "image_offsetH", "type": "int", "description": "贴图高度偏移(1.15p9)", "example": "image_offsetH: 0" },
    { "name": "image_shadow", "type": "imageShadow", "description": "阴影（AUTO/文件名/NONE）", "example": "image_shadow: AUTO" },
    { "name": "image_shadow_frames", "type": "bool", "description": "阴影使用帧动画(1.13.3)", "example": "image_shadow_frames: false" },
    { "name": "shadowOffsetX", "type": "float", "description": "阴影水平偏移", "example": "shadowOffsetX: 0" },
    { "name": "shadowOffsetY", "type": "float", "description": "阴影垂直偏移", "example": "shadowOffsetY: 0" },
    { "name": "teamColoringMode", "type": "teamColoringMode", "description": "队伍着色模式(1.13)", "example": "teamColoringMode: hueAdd" },
    { "name": "teamColorsOnTurret", "type": "bool", "description": "炮塔着色", "example": "teamColorsOnTurret: true" },
    { "name": "scaleImagesTo", "type": "float", "description": "缩放贴图到指定像素", "example": "scaleImagesTo: 1" },
    { "name": "imageScale", "type": "float", "description": "贴图缩放倍率", "example": "imageScale: 1" },
    { "name": "scaleTurretImagesTo", "type": "float", "description": "炮塔缩放", "example": "scaleTurretImagesTo: 1" },
    { "name": "drawLayer", "type": "drawLayer", "description": "渲染层级", "example": "drawLayer: bottom" },
    { "name": "total_frames", "type": "int", "description": "动画总帧数", "example": "total_frames: 1" },
    { "name": "frame_width", "type": "int", "description": "单帧宽度", "example": "frame_width: 64" },
    { "name": "frame_height", "type": "int", "description": "单帧高度", "example": "frame_height: 64" },
    { "name": "default_frame", "type": "int", "description": "默认帧(1.14)", "example": "default_frame: 0" },
    { "name": "rotate_with_direction", "type": "bool", "description": "贴图随方向旋转", "example": "rotate_with_direction: false" },
    { "name": "lock_body_rotation_with_main_turret", "type": "bool", "description": "身体跟随主炮塔旋转", "example": "lock_body_rotation_with_main_turret: true" },
    { "name": "lock_leg_rotation_with_main_turret", "type": "bool", "description": "腿跟随主炮塔旋转(1.13)", "example": "lock_leg_rotation_with_main_turret: true" },
    { "name": "lock_shadow_rotation_with_main_turret", "type": "bool", "description": "阴影跟随主炮塔", "example": "lock_shadow_rotation_with_main_turret: true" },
    { "name": "dustEffect", "type": "bool", "description": "陆地移动灰尘效果", "example": "dustEffect: true" },
    { "name": "splastEffect", "type": "bool", "description": "水面移动效果", "example": "splastEffect: true" },
    { "name": "dustEffectReverse", "type": "bool", "description": "后退灰尘效果", "example": "dustEffectReverse: true" },
    { "name": "splastEffectReverse", "type": "bool", "description": "后退水面效果", "example": "splastEffectReverse: true" },
    { "name": "icon_zoomed_out", "type": "string", "description": "缩放图标", "example": "icon_zoomed_out: icon.png" },
    { "name": "icon_zoomed_out_neverShow", "type": "bool", "description": "隐藏缩放图标", "example": "icon_zoomed_out_neverShow: false" },
    { "name": "icon_build", "type": "string", "description": "建造面板图标", "example": "icon_build: icon.png" },
    { "name": "disableLowHpFire", "type": "bool", "description": "残血火焰(1.13.3)", "example": "disableLowHpFire: false" },
    { "name": "disableLowHpSmoke", "type": "bool", "description": "残血烟雾(1.13.3)", "example": "disableLowHpSmoke: false" },
    { "name": "showTransportBar", "type": "bool", "description": "运输栏(1.13.3)", "example": "showTransportBar: false" },
    { "name": "showHealthBar", "type": "bool", "description": "血条(1.13.3)", "example": "showHealthBar: true" },
    { "name": "showEnergyBar", "type": "bool", "description": "能量条(1.13.3)", "example": "showEnergyBar: false" },
    { "name": "showShieldBar", "type": "bool", "description": "护盾条(1.14)", "example": "showShieldBar: false" },
    { "name": "showQueueBar", "type": "bool", "description": "队列进度条(1.14)", "example": "showQueueBar: false" },
    { "name": "showShotDelayBar", "type": "bool", "description": "射击冷却条(1.15)", "example": "showShotDelayBar: false" },
    { "name": "showSelectionIndicator", "type": "bool", "description": "选中指示器(1.15p9)", "example": "showSelectionIndicator: false" },
    { "name": "whenBeingBuiltMakeTransparentTill", "type": "float", "description": "建造时透明度(1.13)", "example": "whenBeingBuiltMakeTransparentTill: 0.4" },
    { "name": "isVisible", "type": "bool", "description": "是否可见(1.13.3)", "example": "isVisible: true" },
    { "name": "isVisibleToEnemies", "type": "bool", "description": "对敌人隐形(1.14)", "example": "isVisibleToEnemies: false" },
    { "name": "movementEffect", "type": "string", "description": "自定义移动特效(1.13)", "example": "movementEffect: smoke" },
    { "name": "movementEffectReverse", "type": "string", "description": "自定义后退特效(1.13)", "example": "movementEffectReverse: smoke" },
    { "name": "movementEffectRate", "type": "float", "description": "移动特效频率(1.13)", "example": "movementEffectRate: 10" },
    { "name": "repairEffect", "type": "string", "description": "修理特效(1.13)", "example": "repairEffect: CUSTOM:mist*5" },
    { "name": "repairEffectAtTarget", "type": "string", "description": "目标端修理特效(1.13)", "example": "repairEffectAtTarget: CUSTOM:greensparks*2" },
    { "name": "repairEffectRate", "type": "int", "description": "修理特效频率(1.13)", "example": "repairEffectRate: 20" },
    { "name": "reclaimEffect", "type": "string", "description": "回收特效(1.13.3)", "example": "reclaimEffect: CUSTOM:sap*5" },
    { "name": "reclaimEffectAtTarget", "type": "string", "description": "目标端回收特效(1.13.3)", "example": "reclaimEffectAtTarget: CUSTOM:redsparks*2" }
  ]
}
