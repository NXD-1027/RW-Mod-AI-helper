{
  "name": "action",
  "description": "动作（UI可见）",
  "data": [
    {
      "name": "text",
      "type": "string",
      "description": "Button text (supports dynamic text)",
      "example": "text: 开火"
    },
    {
      "name": "textPostFix",
      "type": "string",
      "description": "Text postfix (1.15)",
      "example": "textPostFix: ]"
    },
    {
      "name": "description",
      "type": "string",
      "description": "Description",
      "example": "description: 对目标区域开火"
    },
    {
      "name": "displayType",
      "type": "displayType",
      "description": "Display type",
      "example": "displayType: upgrade"
    },
    {
      "name": "displayRemainingStockpile",
      "type": "bool",
      "description": "Display remaining stockpile (true/false)",
      "example": "displayRemainingStockpile: true"
    },
    {
      "name": "pos",
      "type": "float",
      "description": "Position",
      "example": "pos: 1"
    },
    {
      "name": "iconImage",
      "type": "string",
      "description": "Icon image",
      "example": "iconImage: fireShot.png"
    },
    {
      "name": "iconExtraImage",
      "type": "string",
      "description": "Icon extra image",
      "example": "iconExtraImage: fireShotNo.png"
    },
    {
      "name": "iconExtraColor",
      "type": "string",
      "description": "Icon extra color",
      "example": "iconExtraColor: #ff0000"
    },
    {
      "name": "price",
      "type": "string",
      "description": "Price",
      "example": "price: credits=5"
    },
    {
      "name": "isActive",
      "type": "bool",
      "description": "Is active (true/false)",
      "example": "isActive: true"
    },
    {
      "name": "isVisible",
      "type": "bool",
      "description": "Is visible (true/false)",
      "example": "isVisible: true"
    },
    {
      "name": "isLocked",
      "type": "bool",
      "description": "Is locked (true/false)",
      "example": "isLocked: false"
    },
    {
      "name": "isLockedMessage",
      "type": "string",
      "description": "Is locked message",
      "example": "isLockedMessage: 弹药不足"
    },
    {
      "name": "allowMultipleInQueue",
      "type": "bool",
      "description": "Allow multiple in queue (true/false)",
      "example": "allowMultipleInQueue: true"
    },
    {
      "name": "onlyOneUnitAtATime",
      "type": "bool",
      "description": "Only one unit at a time (true/false)",
      "example": "onlyOneUnitAtATime: true"
