      "type": "bool",
      "description": "Is gui blinking (true/false)",
      "example": "isGuiBlinking: true"
    },
    {
      "name": "autoTrigger",
      "type": "string",
      "description": "Auto-trigger condition (LogicBoolean)",
      "example": "autoTrigger: if self.overWater()"
    },
    {
      "name": "autoTriggerOnEvent",
      "type": "string",
      "description": "Auto trigger on event",
      "example": "autoTriggerOnEvent: queueItemCancelled"
    },
    {
      "name": "autoTriggerOnEventRecursionLimit",
      "type": "int",
      "description": "Auto trigger on event recursion limit",
      "example": "autoTriggerOnEventRecursionLimit: 4"
