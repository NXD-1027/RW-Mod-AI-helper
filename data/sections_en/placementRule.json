    },
    {
      "name": "cannotPlaceMessage",
      "type": "string",
      "description": "Cannot place message",
      "example": "cannotPlaceMessage: 需要工厂附近"
    },
    {
      "name": "checkEachTile",
      "type": "bool",
      "description": "Check each tile (true/false)",
      "example": "checkEachTile: true"
