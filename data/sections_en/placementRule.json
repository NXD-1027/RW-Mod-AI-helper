      "description": "Search team",
      "example": "searchTeam: ally"
    },
    {
      "name": "searchOffsetX",
      "type": "float",
      "description": "Search offset x",
      "example": "searchOffsetX: 0"
    },
    {
      "name": "searchOffsetY",
      "type": "float",
      "description": "Search offset y",
      "example": "searchOffsetY: 0"
    },
    {
      "name": "searchDistance",
      "type": "float",
      "description": "Search distance",
      "example": "searchDistance: 100"
    },
    {
